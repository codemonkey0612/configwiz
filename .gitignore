# Ignore all files in these directories
sessions/*
uploads/*

# But keep the directories
!sessions/.gitkeep
!uploads/.gitkeep

# Other files to ignore
cookies.txt
*.log
.DS_Store
Thumbs.db

# Sensitive configuration files
includes/config.php

# Other common files to ignore
.env 
branch_structure.json
temp_auto_push.bat
temp_interactive_push.bat
.gitignore
